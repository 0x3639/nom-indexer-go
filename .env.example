# nom-indexer-go local environment.
# Copy this file to `.env` and fill in real values; .env is gitignored.
#
# `docker compose up` will fail until POSTGRES_PASSWORD is set.

# Postgres credentials used by both the postgres container and the indexer.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme-local-dev-only
POSTGRES_DB=nom_indexer

# Override the default Zenon node WebSocket URL if needed.
# NODE_URL_WS=wss://test.hc1node.com
# When running the bundled local znnd (compose --profile local-node):
# NODE_URL_WS=ws://znnd:35998

# --- Sync watchdog: multi-node failover ----------------------------------
# NODE_URL_WS above is the primary (nodes[0]). NODE_URL_FALLBACKS is a
# comma-separated, ordered list of failover candidates the watchdog swaps
# to when the primary lags or goes unreachable, and fails back from when it
# recovers. The HTTP-RPC probe URL is auto-derived for the well-known WS
# port 35998 (HTTP-RPC on 35997); other ports need an explicit probe_url,
# which is only expressible via config.yaml's indexer.nodes block.
# NODE_URL_FALLBACKS=wss://my.hc1node.com:35998,wss://test.hc1node.com:35998
# Off by default. Set true to activate drift detection + failover/failback.
# INDEXER_WATCHDOG_ENABLED=true

# --- Local znnd node (compose `local-node` profile) -----------------------
# These are read only when you opt into the local-node compose profile:
#   docker compose --profile local-node up -d --build
# Without --profile, the znnd / znnd-bootstrap services are not created.

# go-zenon git ref to build znnd from. Pin to a tag/commit in production.
# ZNND_GIT_REF=master

# Public snapshot URL to bootstrap chain data from. A sibling .hash file
# (same path, .hash extension) must contain the sha256 of the zip.
# Leave empty to skip the snapshot install and sync znnd from genesis.
# ZNND_BOOTSTRAP_URL=

# Force the bootstrap to run even if /data/nom already exists. Existing
# nom/, network/, consensus/ dirs are moved aside with a timestamp suffix
# (not deleted). Set true for a one-shot re-bootstrap, then unset.
# ZNND_FORCE_BOOTSTRAP=false

# Set to true to fill momentum gaps on startup (slower, off by default).
# BACKFILL_ON_STARTUP=false

# --- Public reverse proxy (compose -f docker-compose.caddy.yml) -----------
# Only read when you include the Caddy overlay. Omit the overlay entirely
# for local dev and hit the host ports directly (http://localhost:8080).
#
# Domains Caddy serves. For a public deployment, set real subdomains that
# resolve to this host — Caddy auto-provisions Let's Encrypt certs. Left
# unset, they default to api.localhost / mcp.localhost, for which Caddy uses
# its internal self-signed CA (no public DNS or email needed). On macOS add
# `127.0.0.1 api.localhost mcp.localhost` to /etc/hosts; Linux resolves
# *.localhost to loopback automatically.
# API_DOMAIN=api.example.com
# MCP_DOMAIN=mcp.example.com
# ACME account email (cert-expiry notices). Required for real public certs;
# ignored by the internal CA used for *.localhost.
# ACME_EMAIL=you@example.com

# --- API server (cmd/api) -------------------------------------------------
# Required. Used to sign HS256 JWTs. Generate one with:
#   openssl rand -base64 48
# Admins mint per-consumer tokens via `cmd/jwt-issue`; there is no
# token-mint HTTP endpoint. Rotation = re-issue every active token.
API_JWT_SECRET=

# Optional API tuning.
# API_PORT=8080
# API_METRICS_PORT=9090
# Comma-separated origin allowlist. Empty disables CORS entirely.
# API_CORS_ALLOWED_ORIGINS=https://app.example.com,https://localhost:3000
# Per-subject (or per-IP) rate limit, requests/minute.
# API_RATE_LIMIT_PER_MINUTE=60

# --- MCP server (cmd/mcp) -------------------------------------------------
# Optional. If unset, the MCP server uses API_JWT_SECRET above. Set this
# only when you want isolated key material between REST and MCP — both
# `cmd/jwt-issue` invocations will then need --secret-env pointed at the
# right value.
# MCP_JWT_SECRET=

# Optional MCP tuning.
# MCP_PORT=8081
# MCP_METRICS_PORT=9091
# Comma-separated origin allowlist for browser MCP clients. Empty disables CORS.
# MCP_CORS_ALLOWED_ORIGINS=https://app.example.com
# Per-subject rate limit, MCP transport requests/minute.
# MCP_RATE_LIMIT_PER_MINUTE=60
