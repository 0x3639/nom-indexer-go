# nom-indexer-go configuration example
# Copy this file to config.yaml and customize as needed
# Environment variables take precedence over this file

node:
  # WebSocket URL for Zenon node
  # Public testnet: wss://test.hc1node.com
  # Local node: ws://127.0.0.1:35998
  ws_url: "wss://test.hc1node.com"

database:
  host: "localhost"
  port: 5432
  name: "nom_indexer"
  user: "postgres"
  # Password can be set here OR via DATABASE_PASSWORD env var (env var takes precedence)
  password: "your-secure-password-here"
  pool_size: 10

logging:
  # debug, info, warn, error
  level: "info"
  # json, console
  format: "console"

cron:
  # Interval for updating pillar voting activity
  voting_activity_interval: "10m"
  # Interval for updating token holder counts
  token_holders_interval: "10m"

# Used only by cmd/api (the HTTP API service). The indexer ignores this block.
api:
  # Public API port.
  port: 8080
  # Prometheus /metrics port (separate listener so the public API does
  # not leak operational data).
  metrics_port: 9090
  # HS256 secret. Prefer the API_JWT_SECRET env var; never commit a
  # real value here. Required — the API refuses to start without it.
  jwt_secret: ""
  # Comma-separated origin allowlist. Empty = CORS disabled.
  cors_allowed_origins: ""
  # Per-subject (or per-IP) rate limit, requests/minute.
  rate_limit_per_minute: 60

# Used only by cmd/mcp (the hosted MCP server for AI agents). The
# indexer and API ignore this block.
mcp:
  # Public MCP port (Streamable HTTP at POST /mcp).
  port: 8081
  # Prometheus /metrics port (separate listener).
  metrics_port: 9091
  # HS256 secret. Leave empty to share api.jwt_secret with the REST API;
  # set explicitly to isolate the two surfaces. Prefer the MCP_JWT_SECRET
  # env var over checking a value in here.
  jwt_secret: ""
  # Comma-separated origin allowlist for browser MCP clients.
  cors_allowed_origins: ""
  # Per-subject rate limit, MCP transport requests/minute.
  rate_limit_per_minute: 60

# Indexer-process-only settings (cmd/indexer). The API and MCP processes
# ignore this block.
indexer:
  # Ordered priority list of upstream nodes. nodes[0] is the primary
  # (must be WS-capable since the subscription requires WebSockets).
  # Subsequent entries are fallback candidates that the sync watchdog
  # fails over to when the primary degrades.
  #
  # If this block is omitted, the legacy NODE_URL_WS env var becomes
  # nodes[0] with label "primary" and NODE_URL_FALLBACKS (comma-
  # separated) becomes nodes[1..] with auto-labels "fallback-1", etc.
  nodes:
    # Default: use the docker-compose default upstream (public testnet).
    # Most operators leave this as-is and override via NODE_URL_WS.
    - url: "wss://test.hc1node.com"
      label: "primary"
    # Uncomment when running with `docker compose --profile local-node`:
    # - url: "ws://znnd:35998"
    #   label: "local-znnd"
    # And/or add remote fallbacks the watchdog can swap to on failure:
    # - url: "wss://my.hc1node.com:35998"
    #   label: "hc1node-remote"
  # Sync watchdog (drift detection + failover). Default off; opt-in via
  # config.yaml or INDEXER_WATCHDOG_ENABLED=true.
  watchdog:
    enabled: false
    interval: "30s"
    stall_threshold: "60s"
    indexer_drift_threshold: 3
    node_drift_threshold: 3
    unhealthy_streak: 2
    failback_streak: 5
    tolerate_missing_syncinfo: true
  # Indexer-side HTTP server for /healthz and /readyz.
  health:
    enabled: true
    port: 9092
